{
  "name": "quickrecall",
  "version": "4.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "copy:wasm": "node scripts/copy-pdfium-wasm.mjs",
    "dev": "pnpm copy:wasm && next dev",
    "build": "pnpm copy:wasm && next build",
    "start": "next start",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "lint:ci": "biome ci ./src",
    "format": "biome format --write ./src",
    "check": "biome check --write ./src",
    "typecheck": "tsc --noEmit",
    "test": "echo \"No tests yet — placeholder\" && exit 0",
    "knip": "knip",
    "audit:lh": "pnpm dlx unlighthouse --site https://quickrecall.vercel.app"
  },
